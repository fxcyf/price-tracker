# ─── Local Development ────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# The docker-compose service hostnames (db, redis) are used here.
# For running the backend outside Docker, change db→localhost, redis→localhost.

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/pricetracker
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/pricetracker

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Celery Beat schedule
CHECK_INTERVAL_HOURS=24

# Email (SMTP) — leave SMTP_USER empty to disable email alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# LLM fallback (optional — only called on first import of a new domain)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App
DEBUG=false
FRONTEND_URL=http://localhost:5173


# ─── Railway Production (set these in the Railway dashboard) ──────────────────
# Railway's Postgres plugin provides individual PGUSER/PGPASSWORD/etc. variables.
# Construct the two DATABASE_URL variants using Railway's reference syntax:
#
# DATABASE_URL=postgresql+asyncpg://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
# DATABASE_URL_SYNC=postgresql://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
#
# Railway's Redis plugin:
# CELERY_BROKER_URL=${{Redis.REDIS_URL}}
# CELERY_RESULT_BACKEND=${{Redis.REDIS_URL}}
#
# Worker service start command:
#   /app/entrypoint.sh celery -A app.tasks.celery_app worker --loglevel=info --concurrency=2
#
# Beat service start command:
#   /app/entrypoint.sh celery -A app.tasks.celery_app beat --loglevel=info
